% =====================================================================
%  structural-atlas.sty
%  A reusable TikZ style package for "Structural Atlas"-flavored figures:
%  warm-paper backgrounds, muted jewel-tone curves, soft glow fills,
%  gray probe axes, and small-caps captions.
%
%  Usage:  \usepackage{tex/sty/structural-atlas}
%  Requires: tikz, xcolor (loaded here).
% =====================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tex/sty/structural-atlas}[2026/06/29 v1.0 Structural Atlas figure styles]

\RequirePackage{tikz}
\RequirePackage{amsmath}
\usetikzlibrary{arrows.meta,calc,backgrounds,decorations.pathreplacing,
                positioning,fadings}

% ---------------------------------------------------------------------
% 1. PALETTE  (cleaned from the source atlas; tweak in one place)
% ---------------------------------------------------------------------
\definecolor{atlaspaper}{HTML}{F4EFE4}  % warm cream background
\definecolor{atlasink}{HTML}{33312E}    % warm near-black: axes & text
\definecolor{atlasgray}{HTML}{9A958C}   % muted gray: dashed droplines

\definecolor{atlasblue}{HTML}{2E6F9E}   % primary curve / MVT / Lipschitz
\definecolor{atlasgreen}{HTML}{4C8C3F}  % IVT path, secants
\definecolor{atlasred}{HTML}{C0473B}    % Rolle, tangents
\definecolor{atlasgold}{HTML}{D69A2A}   % convexity
\definecolor{atlasmagenta}{HTML}{B84A86}% inflection
\definecolor{atlasteal}{HTML}{2A9D9A}   % local min
\definecolor{atlasorange}{HTML}{D17A2E} % local max
\definecolor{atlasconegreen}{HTML}{6BA84F} % Lipschitz cone / secant

% ---------------------------------------------------------------------
% 2. CORE STYLES
% ---------------------------------------------------------------------
% Paint a figure's paper background. Apply to the tikzpicture options:
%   \begin{tikzpicture}[atlas]
\tikzset{
  atlas/.style={
    show background rectangle,
    background rectangle/.style={fill=atlaspaper, rounded corners=2pt},
  },
  % Probe axes: muted, arrow-tipped, thin.
  atlas axes/.style={
    atlasink, line width=0.7pt, line cap=round,
    -{Stealth[length=4pt,width=3pt]},
  },
  % The crisp curve stroke (color supplied separately).
  atlas curve/.style={
    line width=1.5pt, line cap=round, line join=round,
  },
  % A secant / auxiliary straight probe line.
  atlas probe/.style={
    line width=1.1pt, line cap=round,
  },
  % Dashed gray dropline from a feature down to an axis.
  dropline/.style={
    atlasgray, line width=0.6pt, dash pattern=on 2pt off 2pt,
  },
  % A solid feature dot.
  atlas dot/.style={
    fill=atlasink, draw=atlaspaper, line width=0.4pt,
    circle, inner sep=0pt, minimum size=4.2pt,
  },
  % Math/text label nodes in the atlas ink color.
  atlas label/.style={atlasink, font=\normalsize},
}

% ---------------------------------------------------------------------
% 3. THE GLOW CURVE  (the signature look)
%    Vertical gradient fill clipped under a plotted curve, a soft halo,
%    and a crisp stroke on top.  pgfkeys interface for legibility.
%
%    \glowcurve{ color=atlasblue, domain=0:5, axis=0, top=4, expr={\x} }
%
%    Keys:
%      color   curve + glow color            (default atlasblue)
%      domain  a:b  x-range of the plot      (required)
%      axis    y-value of the baseline       (default 0)
%      top     y-value of fill rectangle top (default 6) -- set >= curve max
%      expr    function of \x, braced        (required)
%      samples plot samples                  (default 100)
%      stroke  crisp stroke width            (default 1.5pt)
%      fillmax glow opacity at the curve %    (default 38)
%      fillmin glow opacity at the axis  %    (default 3)
%      halo    halo line width               (default 6pt)
% ---------------------------------------------------------------------
\makeatletter
\pgfkeys{
  /glow/.cd,
  color/.initial=atlasblue,
  domain/.initial=0:1,
  axis/.initial=0,
  top/.initial=6,
  expr/.initial={\x},
  samples/.initial=100,
  stroke/.initial=1.5pt,
  fillmax/.initial=24,
  fillmin/.initial=2,
  halo/.initial=5pt,
}
\newcommand{\glowcurve}[1]{%
  \begingroup
  \pgfkeys{/glow/.cd,#1}%
  \edef\gl@color{\pgfkeysvalueof{/glow/color}}%
  \edef\gl@domain{\pgfkeysvalueof{/glow/domain}}%
  \edef\gl@axis{\pgfkeysvalueof{/glow/axis}}%
  \edef\gl@top{\pgfkeysvalueof{/glow/top}}%
  \edef\gl@samples{\pgfkeysvalueof{/glow/samples}}%
  \edef\gl@stroke{\pgfkeysvalueof{/glow/stroke}}%
  \edef\gl@fmax{\pgfkeysvalueof{/glow/fillmax}}%
  \edef\gl@fmin{\pgfkeysvalueof{/glow/fillmin}}%
  \edef\gl@halo{\pgfkeysvalueof{/glow/halo}}%
  \def\gl@expr{\pgfkeysvalueof{/glow/expr}}%
  % -- extract a and b from domain a:b
  \expandafter\gl@splitdomain\gl@domain\@nil
  % -- (1) gradient fill, clipped to the area under the curve
  \begin{scope}
    \clip (\gl@a,\gl@axis)
      -- plot[domain=\gl@domain,samples=\gl@samples,smooth] (\x,{\gl@expr})
      -- (\gl@b,\gl@axis) -- cycle;
    \shade[top color=\gl@color!\gl@fmax, bottom color=\gl@color!\gl@fmin]
      (\gl@a,\gl@axis) rectangle (\gl@b,\gl@top);
  \end{scope}
  % -- (2) soft glow: two layers (wide faint + tight brighter)
  \draw[\gl@color, line width=\gl@halo, opacity=0.10, line cap=round]
    plot[domain=\gl@domain,samples=\gl@samples,smooth] (\x,{\gl@expr});
  \draw[\gl@color, line width=0.55\gl@halo, opacity=0.22, line cap=round]
    plot[domain=\gl@domain,samples=\gl@samples,smooth] (\x,{\gl@expr});
  % -- (3) crisp stroke
  \draw[\gl@color, atlas curve, line width=\gl@stroke]
    plot[domain=\gl@domain,samples=\gl@samples,smooth] (\x,{\gl@expr});
  \endgroup
}
% split "a:b" into \gl@a and \gl@b
\def\gl@splitdomain#1:#2\@nil{\def\gl@a{#1}\def\gl@b{#2}}
\makeatother

% ---------------------------------------------------------------------
% 3b. GLOW STROKE  (halo + crisp line, NO fill) -- for curves drawn over
%     Riemann rectangles, where the bars already supply the fill.
%       \glowstroke{color}{a:b}{expr}
% ---------------------------------------------------------------------
\newcommand{\glowstroke}[3]{%
  \draw[#1, line width=5pt, opacity=0.10, line cap=round]
    plot[domain=#2,samples=100,smooth] (\x,{#3});
  \draw[#1, line width=2.75pt, opacity=0.18, line cap=round]
    plot[domain=#2,samples=100,smooth] (\x,{#3});
  \draw[#1, atlas curve]
    plot[domain=#2,samples=100,smooth] (\x,{#3});
}

% ---------------------------------------------------------------------
% 4. CAPTION  (small-caps, two-line, beneath a figure)
%    \atlascaption{1}{Mean Value Theorem (MVT)}{The Tangent Guard}
% ---------------------------------------------------------------------
\newcommand{\atlascaption}[3]{%
  \shortstack{\scshape\footnotesize\color{atlasink}%
    Figure~#1.\ \textbf{#2:}\\[1pt]\textbf{#3}}%
}

\endinput
